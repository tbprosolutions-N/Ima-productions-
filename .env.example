# =============================================================================
# Required for Vercel production (paste into Vercel → Project → Settings → Environment Variables)
# =============================================================================

# Supabase (from Dashboard → Settings → API)
# Production project: oerqkyzfsdygmmsonrgz — MUST match in both frontend and Vercel
VITE_SUPABASE_URL=https://oerqkyzfsdygmmsonrgz.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key

# App identity
VITE_APP_URL=https://npc-am.com
VITE_APP_NAME=npc-am
VITE_APP_VERSION=1.0.0

# Optional: set to "true" ONLY in development for demo login; leave unset or "false" in production
# VITE_DEMO_BYPASS=false

# =============================================================================
# Resend (email sending)
# =============================================================================
# Set in Supabase secrets for Edge Functions: supabase secrets set RESEND_API_KEY=re_...
# Set in Supabase secrets for Edge Functions: supabase secrets set RESEND_FROM="NPC Collective <noreply@npc-am.com>"
# Optional frontend override for agreement emails: VITE_EMAIL_FROM="NPC Collective <noreply@npc-am.com>"
# RESEND_API_KEY=re_your_resend_api_key
# RESEND_FROM=NPC Collective <noreply@npc-am.com>

# =============================================================================
# Vercel API Routes (Morning / Green Invoice + calendar-invite proxy)
# =============================================================================
# Required for /api/morning, /api/morning-save-credentials, /api/calendar-invite.
# Set in Vercel → Environment Variables.
# SUPABASE_URL=https://oerqkyzfsdygmmsonrgz.supabase.co (same as VITE_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_service_role_key
# SUPABASE_ANON_KEY=eyJ... (same as VITE_SUPABASE_ANON_KEY — for calendar-invite proxy)
# Optional: MORNING_BASE_URL=https://api.greeninvoice.co.il/api/v1

# Morning credentials are stored per-agency in integration_secrets (via Settings → גיבוי נתונים).
# No MORNING_API_KEY/MORNING_API_SECRET needed in env for production.

# =============================================================================
# Supabase Edge Functions (set via: supabase secrets set KEY=value)
# =============================================================================
# SUPABASE_SERVICE_ROLE_KEY=
# RESEND_API_KEY=
# RESEND_FROM=NPC Collective <noreply@npc-am.com>
# RESEND_REPLY_TO=npcollectivebooking@gmail.com
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=
# ANTHROPIC_API_KEY=  (for invoice extraction Vision)

# Optional: for login-fix migration from CLI (do NOT commit):
# SUPABASE_ACCESS_TOKEN=
# DATABASE_URL=

# =============================================================================
# Production
# =============================================================================
# Domain: https://npc-am.com (Vercel custom domain)
# Ensure Supabase Auth → URL Configuration: Site URL and Redirect URLs include https://npc-am.com
